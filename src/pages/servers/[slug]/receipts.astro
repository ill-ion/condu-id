---
export const prerender = false;

import Base from "@layouts/Base.astro";
import PageHeader from "@components/PageHeader.astro";
import StatusPill from "@components/StatusPill.astro";
import EmptyState from "@components/EmptyState.astro";
import { api, ApiClientError } from "@lib/api/client";
import type { ReceiptSummary, Server } from "@lib/api/types";

const { slug } = Astro.params as { slug: string };
const url = new URL(Astro.request.url);
const cursor = url.searchParams.get("cursor") ?? undefined;
const anchoredParam = url.searchParams.get("anchored");
const anchored =
  anchoredParam === "true" ? true : anchoredParam === "false" ? false : undefined;

let server: Server | null = null;
let receipts: ReceiptSummary[] = [];
let nextCursor: string | null = null;
let hasMore = false;

try {
  server = await api.getServer(slug);
  const page = await api.listServerReceipts(slug, { cursor, limit: 30, anchored });
  receipts = page.data;
  nextCursor = page.pagination.next_cursor;
  hasMore = page.pagination.has_more;
} catch (e) {
  if (e instanceof ApiClientError && e.notFound) {
    Astro.response.status = 404;
    return Astro.redirect("/servers", 302);
  }
  throw e;
}

if (!server) return Astro.redirect("/servers", 302);
---

<Base title={`Receipts — ${server.name || server.slug}`}>
  <div class="container-page py-16">
    <nav class="text-sm font-sans text-ink-muted mb-2">
      <a class="link" href="/servers">Servers</a>
      <span class="px-2">/</span>
      <a class="link" href={`/servers/${server.slug}`}>{server.name || server.slug}</a>
      <span class="px-2">/</span>
      <span>Receipts</span>
    </nav>
    <PageHeader
      eyebrow="Receipts emitted by"
      title={server.name || server.slug}
      subtitle="Every action receipt this server has signed and emitted, ordered most-recent first. Each row links to the verifiable receipt."
    />

    <div class="mb-6 flex flex-wrap gap-2 items-center text-sm font-sans">
      <a class={anchored === undefined ? "btn" : "btn-ghost"} href={`/servers/${server.slug}/receipts`}>All</a>
      <a class={anchored === true ? "btn" : "btn-ghost"} href={`/servers/${server.slug}/receipts?anchored=true`}>Anchored</a>
      <a class={anchored === false ? "btn" : "btn-ghost"} href={`/servers/${server.slug}/receipts?anchored=false`}>Pending</a>
    </div>

    {receipts.length === 0 ? (
      <EmptyState title="No receipts" body="None match this filter." />
    ) : (
      <>
        <div class="border border-rule">
          {receipts.map((r, i) => (
            <a
              href={`/receipts/${r.id}`}
              class={`grid grid-cols-1 md:grid-cols-[12rem_1fr_auto] gap-4 px-5 py-4 no-underline hover:bg-paper-dark ${i > 0 ? "border-t border-rule" : ""}`}
            >
              <div class="font-mono text-xs text-ink-muted truncate">{r.id}</div>
              <div class="min-w-0">
                <div class="text-sm text-ink truncate">
                  {r.action_type}
                  {r.agent_slug && (
                    <span class="text-ink-muted"> · {r.agent_slug}</span>
                  )}
                </div>
                <div class="font-mono text-xs text-ink-muted truncate mt-0.5">{r.signed_by}</div>
              </div>
              <div class="flex items-center md:justify-end gap-3">
                <span class="text-xs text-ink-muted whitespace-nowrap">
                  {new Date(r.created_at).toLocaleString()}
                </span>
                <StatusPill status={r.anchored ? "pass" : "skipped"} label={r.anchored ? "Anchored" : "Pending"} />
              </div>
            </a>
          ))}
        </div>

        <nav class="mt-8 flex items-center justify-between text-sm font-sans text-ink-muted">
          <a class="link" href={`/servers/${server.slug}`}>← Back to server</a>
          {hasMore && nextCursor && (
            <a class="btn" href={`/servers/${server.slug}/receipts?cursor=${encodeURIComponent(nextCursor)}${anchored !== undefined ? `&anchored=${anchored}` : ""}`}>
              Next page →
            </a>
          )}
        </nav>
      </>
    )}
  </div>
</Base>
