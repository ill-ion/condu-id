---
export const prerender = false;

import Base from "@layouts/Base.astro";
import PageHeader from "@components/PageHeader.astro";
import StatusPill from "@components/StatusPill.astro";
import EmptyState from "@components/EmptyState.astro";
import { api, ApiClientError } from "@lib/api/client";
import type { Agent, Server } from "@lib/api/types";

const { slug } = Astro.params as { slug: string };
const url = new URL(Astro.request.url);
const cursor = url.searchParams.get("cursor") ?? undefined;

let server: Server | null = null;
let agents: Agent[] = [];
let nextCursor: string | null = null;
let hasMore = false;

try {
  server = await api.getServer(slug);
  const page = await api.listServerAgents(slug, { cursor, limit: 30 });
  agents = page.data;
  nextCursor = page.pagination.next_cursor;
  hasMore = page.pagination.has_more;
} catch (e) {
  if (e instanceof ApiClientError && e.notFound) {
    Astro.response.status = 404;
    return Astro.redirect("/servers", 302);
  }
  throw e;
}

if (!server) return Astro.redirect("/servers", 302);
---

<Base title={`Agents — ${server.name || server.slug}`}>
  <div class="container-page py-16">
    <nav class="text-sm font-sans text-ink-muted mb-2">
      <a class="link" href="/servers">Servers</a>
      <span class="px-2">/</span>
      <a class="link" href={`/servers/${server.slug}`}>{server.name || server.slug}</a>
      <span class="px-2">/</span>
      <span>Agents</span>
    </nav>
    <PageHeader
      eyebrow="Agents under"
      title={server.name || server.slug}
      subtitle={`Every agent registered under did:web:${server.slug}.`}
    />

    {agents.length === 0 ? (
      <EmptyState title="No agents yet" body="This server hasn't emitted any agent receipts." />
    ) : (
      <>
        <div class="border border-rule">
          {agents.map((a, i) => (
            <a
              href={`/agents/${a.slug}`}
              class={`flex items-start gap-4 px-5 py-4 no-underline hover:bg-paper-dark ${i > 0 ? "border-t border-rule" : ""}`}
            >
              <div class="flex-1 min-w-0">
                <div class="font-serif text-lg text-ink leading-tight">{a.name || a.local_id || a.slug}</div>
                <div class="font-mono text-xs text-ink-muted mt-1 truncate">{a.did}</div>
                {a.description && (
                  <p class="text-sm text-ink-muted mt-2 line-clamp-2 leading-relaxed">
                    {a.description}
                  </p>
                )}
              </div>
              <div class="flex flex-col items-end gap-2 text-xs font-sans text-ink-muted whitespace-nowrap">
                <span>{a.receipt_count.toLocaleString()} receipts</span>
                {a.deactivated ? (
                  <StatusPill status="fail" label="Deactivated" />
                ) : (
                  <StatusPill status="pass" label="Active" />
                )}
              </div>
            </a>
          ))}
        </div>

        <nav class="mt-8 flex items-center justify-between text-sm font-sans text-ink-muted">
          <a class="link" href={`/servers/${server.slug}`}>← Back to server</a>
          {hasMore && nextCursor && (
            <a class="btn" href={`/servers/${server.slug}/agents?cursor=${encodeURIComponent(nextCursor)}`}>
              Next page →
            </a>
          )}
        </nav>
      </>
    )}
  </div>
</Base>
