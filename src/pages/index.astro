---
import Base from "@layouts/Base.astro";
import StatusPill from "@components/StatusPill.astro";
import { api, ApiClientError } from "@lib/api/client";
import type { Server, ReceiptSummary } from "@lib/api/types";

// Best-effort fetch. If the API is briefly down at build time we still
// want a page; we just degrade gracefully and rely on the directory
// links to pull live data on click.
let topServers: Server[] = [];
let recentReceipts: ReceiptSummary[] = [];
let buildOk = true;

try {
  const [serversPage, receiptsPage] = await Promise.all([
    api.listServers({ limit: 6, has_receipts: true }),
    api.listReceipts({ limit: 5, anchored: true }),
  ]);
  topServers = serversPage.data;
  recentReceipts = receiptsPage.data;
} catch (e) {
  buildOk = false;
  if (!(e instanceof ApiClientError) || e.status >= 500) {
    // Log to build output but don't fail the build.
    console.warn("[homepage] API fetch degraded:", e);
  }
}

const totalServers = topServers.length;
---

<Base title="Condu.ID" description="A neutral identity layer for AI agents and MCP servers — built on RCPT Protocol, anchored to Solana, verifiable in your browser.">

  {/* ── hero ─────────────────────────────────────────────────────── */}
  <section class="container-page pt-20 pb-16 md:pt-32 md:pb-24">
    <div class="max-w-3xl">
      <div class="label mb-6">An open identity standard for AI agents</div>
      <h1 class="font-serif text-4xl md:text-6xl tracking-tight leading-[1.05]">
        Every action an agent takes
        <span class="text-ink-muted">should leave a verifiable trace.</span>
      </h1>
      <p class="mt-8 text-lg text-ink-soft leading-relaxed max-w-prose">
        Condu.ID is the neutral resolver for AI agent and MCP server identity.
        We map agents to W3C decentralized identifiers, anchor their action
        receipts to Solana, and let anyone in the world verify the chain
        without trusting our infrastructure.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a class="btn" href="/servers">Browse servers</a>
        <a class="btn-ghost" href="/about">How verification works</a>
      </div>

      <div class="mt-14 grid sm:grid-cols-3 gap-x-8 gap-y-5 max-w-2xl">
        <div>
          <div class="label">DID method</div>
          <div class="font-serif text-lg mt-1">did:web · did:key</div>
        </div>
        <div>
          <div class="label">Signature</div>
          <div class="font-serif text-lg mt-1">Ed25519 · RFC 8032</div>
        </div>
        <div>
          <div class="label">Canonicalization</div>
          <div class="font-serif text-lg mt-1">JCS · RFC 8785</div>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-rule" />

  {/* ── featured servers ─────────────────────────────────────────── */}
  <section class="container-page py-16">
    <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
      <div>
        <div class="label mb-2">Featured</div>
        <h2 class="font-serif text-2xl md:text-3xl">Active MCP servers</h2>
      </div>
      <a class="link text-sm font-sans" href="/servers">See all servers →</a>
    </div>

    {topServers.length === 0 ? (
      <div class="border border-rule border-dashed p-10 text-center">
        <p class="text-ink-muted">
          The directory is currently warming up. Try the
          <a class="link" href="/servers">full directory page</a>
          which fetches live.
        </p>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-rule border border-rule">
        {topServers.map((s) => (
          <a
            href={`/servers/${s.slug}`}
            class="bg-paper hover:bg-paper-dark transition-colors p-6 flex flex-col gap-3 no-underline"
          >
            <div class="flex items-start justify-between gap-3">
              <div class="font-serif text-xl text-ink leading-tight">
                {s.name || s.slug}
              </div>
              {s.deactivated ? (
                <StatusPill status="fail" label="Deactivated" />
              ) : (
                <StatusPill status="pass" label="Active" />
              )}
            </div>
            <p class="text-sm text-ink-muted line-clamp-3 leading-relaxed">
              {s.description || "No description provided."}
            </p>
            <div class="mt-auto pt-4 flex items-center gap-4 text-xs text-ink-muted font-sans">
              <span>{s.receipt_count.toLocaleString()} receipts</span>
              <span>·</span>
              <span>{s.agent_count.toLocaleString()} agents</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <hr class="border-rule" />

  {/* ── recent anchored receipts ─────────────────────────────────── */}
  {recentReceipts.length > 0 && (
    <section class="container-page py-16">
      <div class="flex items-end justify-between mb-8 gap-4 flex-wrap">
        <div>
          <div class="label mb-2">Latest evidence</div>
          <h2 class="font-serif text-2xl md:text-3xl">Recently anchored</h2>
        </div>
        <a class="link text-sm font-sans" href="/receipts">All receipts →</a>
      </div>
      <div class="border border-rule">
        {recentReceipts.map((r, i) => (
          <a
            href={`/receipts/${r.id}`}
            class={`flex items-center gap-4 px-5 py-4 no-underline hover:bg-paper-dark transition-colors ${i > 0 ? "border-t border-rule" : ""}`}
          >
            <div class="font-mono text-xs text-ink-muted w-32 truncate">
              {r.id}
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm text-ink truncate">
                {r.action_type}{" "}
                <span class="text-ink-muted">·</span>{" "}
                <span class="text-ink-soft">{r.server_slug}</span>
                {r.agent_slug && (
                  <>
                    <span class="text-ink-muted"> / </span>
                    <span class="text-ink-soft">{r.agent_slug}</span>
                  </>
                )}
              </div>
              <div class="text-xs text-ink-muted mt-0.5 font-mono truncate">
                {r.signed_by}
              </div>
            </div>
            <StatusPill
              status={r.anchored ? "pass" : "skipped"}
              label={r.anchored ? "Anchored" : "Pending"}
            />
          </a>
        ))}
      </div>
    </section>
  )}

  <hr class="border-rule" />

  {/* ── operating principle ──────────────────────────────────────── */}
  <section class="container-page py-20">
    <div class="max-w-prose">
      <div class="label mb-3">Operating principle</div>
      <h2 class="font-serif text-2xl md:text-3xl mb-6">
        Don't trust us. Verify locally.
      </h2>
      <p class="text-ink-soft leading-relaxed mb-4">
        Condu.ID is a resolver, not a notary. We can index a receipt, return
        a DID document, and tell you what we think a chain looks like — but
        the answer that matters is the one your browser computes from raw
        bytes, after talking to Solana directly.
      </p>
      <p class="text-ink-soft leading-relaxed mb-4">
        Every receipt page on this site re-runs five checks in your tab:
        canonicalization, Ed25519 signature, delegation chain shape, merkle
        inclusion proof, and Solana confirmation against a public RPC. The
        result you see is the result your browser proved. If our server says
        a receipt is valid and your browser says otherwise, your browser is
        right.
      </p>
      <p class="text-ink-soft leading-relaxed">
        That's the whole architecture. Identity infrastructure that you can
        check yourself, on your own machine, without our cooperation.
      </p>
      <div class="mt-10 flex gap-3">
        <a href="/about" class="btn-ghost">Read the technical brief</a>
        <a href="https://github.com/ill-ion/condu-id-api" class="btn-ghost">
          Inspect the resolver source
        </a>
      </div>
    </div>
  </section>
</Base>
