---
interface Props {
  /** Optional caption above the block. */
  label?: string;
  /** Extra classes — e.g. for max-height + scroll. */
  class?: string;
}

const { label, class: extraClass = "" } = Astro.props;
---

{label && <div class="label mb-2">{label}</div>}
<pre class={`bg-paper-dark border border-rule rounded-sm px-4 py-3 text-xs leading-relaxed font-mono overflow-auto break-all whitespace-pre-wrap ${extraClass}`}><slot /></pre>
