# Public — embedded in client bundles. Safe to commit (the example values).
PUBLIC_API_BASE=https://api.condu.id
PUBLIC_SOLANA_CLUSTER=devnet
PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Server-only secret — set as a Cloudflare Pages encrypted env var in production.
# For local dev, paste your Anthropic API key here.
ANTHROPIC_API_KEY=
